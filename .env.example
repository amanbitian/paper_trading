# ─────────────────────────────────────────────────────────────────────────────
# Paper Trading App — optional environment overrides
#
# ALL of these have safe defaults in docker-compose.yml.
# You only need this file if you want to add paid API keys or override defaults.
#
# Copy to .env (same folder) and fill in the values you need:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── News providers (optional — free Yahoo Finance adapter works without keys) ─
# MARKETAUX_API_TOKEN=your_key_here
# ALPHA_VANTAGE_API_KEY=your_key_here

# ── AI model (optional — defaults to gemma3:12b via Ollama) ──────────────────
# OLLAMA_DEFAULT_MODEL=gemma3:12b
# OLLAMA_FALLBACK_MODEL=mistral-nemo:12b
# OLLAMA_TIMEOUT_SECONDS=90
# OLLAMA_MAX_TOKENS=1500
# LLM_CACHE_TTL_HOURS=24

# ── Market movers tuning (optional) ──────────────────────────────────────────
# MARKET_MOVERS_MAX_ABS_DAILY_CHANGE_PCT=50
# MARKET_MOVERS_MAX_CANDLE_GAP_DAYS=7
# MARKET_MOVERS_REQUIRE_VOLUME=true
