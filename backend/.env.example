APP_ENV=local
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/paper_trading
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTO_MIGRATE_ON_START=false
AUTH_DEBUG_LOG_PASSWORD_CHECKS=false
DEBUG_AUTH_BYPASS=false
DEBUG_AUTH_USER_EMAIL=debug@example.com
DEBUG_AUTH_USER_NAME=debug_user
DEBUG_AUTH_NAME=Debug User
YFINANCE_DEFAULT_PERIOD=1y
YFINANCE_DEFAULT_INTERVAL=1d
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Paper Trading App
EMAIL_ALERTS_ENABLED=false
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
APP_BASE_URL=http://localhost:8501

# Ollama (local LLM) — use host.docker.internal:11434 when backend runs in Docker
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b
OLLAMA_FALLBACK_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_MAX_TOKENS=1500
AI_FEATURES_ENABLED=false
LLM_CACHE_TTL_HOURS=24

# Stock news ingestion
MARKETAUX_API_TOKEN=
ALPHA_VANTAGE_API_KEY=
NEWS_REQUEST_TIMEOUT_SECONDS=12
NEWS_ON_DEMAND_LIMIT=10
NEWS_MARKETAUX_DAILY_LIMIT=100
NEWS_ALPHA_VANTAGE_DAILY_LIMIT=25
